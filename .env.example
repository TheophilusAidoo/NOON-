# =============================================
# NoonShop - Multi-Vendor E-commerce Platform
# =============================================

# ----- Backend (./backend) -----
PORT=5001
FRONTEND_URL=http://localhost:3000

# MySQL Database (use with phpMyAdmin)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/noonshop"

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your_access_token_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars

# Admin commission rate (0.1 = 10%)
ADMIN_COMMISSION_RATE=0.1

# Stripe (test mode - get keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ----- Frontend (./frontend) -----
# Create .env.local with:
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxxxx
