{
  "name": "noon-shop-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run kill-port && sleep 2 && npx nodemon src/index.js",
    "start": "node src/index.js",
    "build": "echo 'No build step for Node backend'",
    "create-admin": "npx prisma db seed",
    "seed-products": "node prisma/seed-products.js",
    "fix-admin": "node scripts/fix-admin.js",
    "kill-port": "lsof -ti:5001 | xargs kill -9 2>/dev/null || true",
    "start-fresh": "npm run kill-port && npm run fix-admin && npm run dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3",
    "stripe": "^17.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.22.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
