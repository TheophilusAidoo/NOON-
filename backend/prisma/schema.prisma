// Multi-Vendor E-commerce Platform - Prisma Schema
// MySQL Database - Production Ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(CUSTOMER)
  isVerified    Boolean   @default(false)
  isApproved    Boolean?  // For sellers - null for non-sellers
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sellerProfile    SellerProfile?
  sellerDeposits   SellerDeposit[]
  products         Product[]
  cart             Cart?
  orders           Order[]
  reviews          Review[]
  orderItems       OrderItem[]
  wishlists        Wishlist[]
  chatSent         ChatMessage[] @relation("ChatSender")
  chatReceived     ChatMessage[] @relation("ChatReceiver")

  @@map("users")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

model SellerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  storeName         String
  storeDescription  String?
  logo              String?
  banner            String?  // Store banner image
  storeLevel        String   @default("C") @map("store_level") // C, B, A, S
  cumulativeRecharge Float   @default(0) @map("cumulative_recharge")
  wholesaleSpend     Float   @default(0) @map("wholesale_spend") // Amount spent buying from admin
  creditScore       Int      @default(100) @map("credit_score") // 0-1000; column: credit_score
  cryptoWalletAddress String? @map("crypto_wallet_address")
  cryptoName         String? @map("crypto_name")
  rating            Float   @default(0)
  totalSales        Int     @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seller_profiles")
}

model SellerDeposit {
  id        String   @id @default(cuid())
  sellerId  String   @map("seller_id")
  amount    Float
  status    String   @default("pending") // pending, approved
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@map("seller_deposits")
}

// ==================== CATALOG ====================

model Category {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  image      String?
  promoLabel String?  // e.g. "UP TO -25%"
  createdAt  DateTime @default(now())

  products Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  image     String?  // Optional image for category-style cards
  createdAt DateTime @default(now())

  products Product[]

  @@map("brands")
}

model Product {
  id            String   @id @default(cuid())
  sellerId      String
  categoryId    String
  brandId       String
  title         String
  description   String
  price         Float
  discountPrice Float?
  stock         Int      @default(0)
  sku           String?  @unique
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  seller         User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brand          Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  images         ProductImage[]
  variants       ProductVariant[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        Review[]
  wishlists      Wishlist[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([brandId])
  @@index([isFeatured])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  imageUrl  String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id           String  @id @default(cuid())
  productId    String
  variantType  String
  variantValue String
  stock        Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

// ==================== CART & WISHLIST ====================

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("cart")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  variantId String?

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// ==================== ORDERS ====================

model Order {
  id              String        @id @default(cuid())
  userId          String
  totalAmount     Float
  paymentStatus   PaymentStatus @default(PENDING)
  orderStatus     OrderStatus   @default(PROCESSING)
  shippingAddress String
  adminCommission Float        @default(0)
  stripePaymentId String?
  couponCode      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([paymentStatus])
  @@index([orderStatus])
  @@map("orders")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id                 String   @id @default(cuid())
  orderId            String
  productId          String
  sellerId           String
  quantity           Int
  price              Float
  wholesaleCost      Float?   @map("wholesale_cost")   // Cost seller pays admin (wholesale items only)
  sellerPaidToAdmin  Boolean  @default(false) @map("seller_paid_to_admin")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  seller  User    @relation(fields: [sellerId], references: [id])

  @@index([orderId])
  @@index([sellerId])
  @@map("order_items")
}

// ==================== REVIEWS ====================

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

// ==================== COUPONS ====================

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Float
  expiryDate     DateTime
  active         Boolean      @default(true)
  usageLimit     Int?
  usageCount     Int          @default(0)
  minOrderAmount Float?
  createdAt      DateTime     @default(now())

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ==================== BANNERS (Admin) ====================

model Banner {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

// ==================== CHAT (Seller <-> Admin) ====================

model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  content   String   @default("")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now())

  sender   User @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ChatReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
  @@map("chat_messages")
}

// ==================== MANUAL PAYMENT METHODS ====================
// Admin-managed crypto/fiat options (name, wallet address, QR code)

model ManualPaymentMethod {
  id            String   @id @default(cuid())
  cryptoName    String   @map("crypto_name")   // e.g. BTC, ETH, USDT
  walletAddress String   @map("wallet_address")
  qrCodeUrl     String?  @map("qr_code_url")  // Uploaded QR image
  active        Boolean  @default(true)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("manual_payment_methods")
}

// ==================== SITE SETTINGS ====================

model SiteSetting {
  id    String   @id @default(cuid())
  key   String   @unique
  value String
  @@map("site_settings")
}

// ==================== NEWSLETTER SUBSCRIBERS ====================

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  @@map("newsletter_subscribers")
}

// ==================== WITHDRAWAL REQUESTS (Sellers) ====================

model WithdrawalRequest {
  id            String   @id @default(cuid())
  sellerId      String
  amount        Float
  walletAddress String?  @map("wallet_address")
  cryptoName    String?  @map("crypto_name")
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sellerId])
  @@map("withdrawal_requests")
}
